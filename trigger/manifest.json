{
  "manifest_version": 3,
  "name": "SaleSeer Trigger",
  "version": "1.1.0",
  "description": "Show a price summary box when Add to Cart is clicked.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.coles.com.au/*",
    "https://www.woolworths.com.au/*",
    "https://www.aldi.com.au/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.coles.com.au/*",
        "https://www.woolworths.com.au/*",
        "https://www.aldi.com.au/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["mock_supermarket_products.json"],
      "matches": [
        "https://www.coles.com.au/*",
        "https://www.woolworths.com.au/*",
        "https://www.aldi.com.au/*"
      ]
    }
  ]
}